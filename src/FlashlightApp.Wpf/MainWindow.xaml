<Window x:Class="FlashlightApp.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FlashlightApp — масова прошивка"
        Height="800" Width="1100"
        MinHeight="640" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Status strip (always visible across tabs) -->
        <Border Grid.Row="0" Background="#2D2D30" Padding="14,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusPort"    Foreground="#DCDCDC" FontSize="13" Text="Порт: …" Margin="0,0,24,0" />
                <TextBlock x:Name="StatusGdb"     Foreground="#DCDCDC" FontSize="13" Text="gdb: …"  Margin="0,0,24,0" />
                <TextBlock x:Name="StatusCatalog" Foreground="#DCDCDC" FontSize="13" Text="Каталог: …" />
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Padding="0">

            <!-- ============================ FLASH TAB ============================ -->
            <TabItem Header="Прошивка" FontSize="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="220" />
                    </Grid.RowDefinitions>

                    <!-- Form -->
                    <Grid Grid.Row="0" Margin="20,16,20,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="40" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Оператор:" VerticalAlignment="Center" FontSize="15" Margin="0,0,0,8" />
                        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="OperatorBox" FontSize="16" Padding="6,4" Margin="0,0,0,8" />
                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Партія:" VerticalAlignment="Center" FontSize="15" Margin="0,0,0,8" />
                        <TextBox   Grid.Row="0" Grid.Column="4" x:Name="BatchBox" FontSize="16" Padding="6,4" Margin="0,0,0,8" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Продукт:" VerticalAlignment="Center" FontSize="15" />
                        <ComboBox  Grid.Row="1" Grid.Column="1" x:Name="ProductCombo" FontSize="16" Padding="6,4" SelectionChanged="ProductCombo_SelectionChanged" />
                        <TextBlock Grid.Row="1" Grid.Column="3" Text="Версія:" VerticalAlignment="Center" FontSize="15" />
                        <TextBlock Grid.Row="1" Grid.Column="4" x:Name="VersionLabel" Text="—" VerticalAlignment="Center" FontSize="16" />
                    </Grid>

                    <Border Grid.Row="1" x:Name="ResultBanner" Margin="20,8,20,8" CornerRadius="10" Background="#E8E8E8">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="ResultText" Text="ГОТОВО ДО ПРОШИВКИ" FontSize="64" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#444" />
                            <TextBlock x:Name="ResultDetail" Text="Натисніть кнопку нижче, щоб прошити плату" FontSize="20" HorizontalAlignment="Center" Margin="0,16,0,0" Foreground="#444" />
                        </StackPanel>
                    </Border>

                    <Button Grid.Row="2" x:Name="FlashButton" Content="ПРОШИТИ ПЛАТУ"
                            FontSize="28" FontWeight="Bold" Height="76"
                            Margin="20,0,20,12" Click="FlashButton_Click"
                            Background="#0078D7" Foreground="White" BorderThickness="0" />

                    <Grid Grid.Row="3" Margin="20,0,20,16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Деталі gdb:" FontSize="13" Foreground="#666" Margin="0,0,0,4" />
                        <TextBox Grid.Row="1" x:Name="GdbOutput"
                                 FontFamily="Cascadia Mono, Consolas, Courier New" FontSize="11"
                                 IsReadOnly="True" VerticalScrollBarVisibility="Auto"
                                 Background="#1E1E1E" Foreground="#DCDCDC" Padding="6"
                                 TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto" />
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============================ HISTORY TAB ============================ -->
            <TabItem Header="Історія" FontSize="14">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" x:Name="BatchSummary" FontSize="15" Text="Завантаження..." VerticalAlignment="Center" />
                        <Button Grid.Column="1" x:Name="HistoryRefresh" Content="Оновити" Padding="14,6" Click="HistoryRefresh_Click" />
                    </Grid>

                    <DataGrid Grid.Row="1" x:Name="HistoryGrid"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserSortColumns="True" CanUserAddRows="False"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              AlternatingRowBackground="#F4F4F4"
                              FontSize="13">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Час (UTC)"
                                                Binding="{Binding TsUtc, StringFormat=yyyy-MM-dd HH:mm:ss}"
                                                Width="160" />
                            <DataGridTextColumn Header="Результат" Binding="{Binding Result}" Width="80" />
                            <DataGridTextColumn Header="Продукт" Binding="{Binding ProductId}" Width="120" />
                            <DataGridTextColumn Header="Версія" Binding="{Binding FirmwareVersion}" Width="100" />
                            <DataGridTextColumn Header="Партія" Binding="{Binding BatchId}" Width="120" />
                            <DataGridTextColumn Header="Оператор" Binding="{Binding Operator}" Width="120" />
                            <DataGridTextColumn Header="мс" Binding="{Binding DurationMs}" Width="60" />
                            <DataGridTextColumn Header="Помилка" Binding="{Binding ErrorCode}" Width="170" />
                            <DataGridTextColumn Header="Ціль (BMP)" Binding="{Binding TargetDetected}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ============================ SETTINGS TAB ============================ -->
            <TabItem Header="Налаштування" FontSize="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20" MaxWidth="780" HorizontalAlignment="Left">

                        <!-- Catalog -->
                        <TextBlock Text="Каталог прошивок" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Шлях до catalog.json:" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="SettingsCatalogPath" Margin="0,4,8,4" />
                            <Button    Grid.Row="0" Grid.Column="2" Content="..." Width="40" Margin="0,4,0,4" Click="PickCatalogPath_Click" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Обовʼязковий підпис:" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <CheckBox  Grid.Row="1" Grid.Column="1" x:Name="SettingsRequireSigned" Margin="0,8,0,4"
                                       Content="Відмовляти у роботі, якщо catalog.json не підписано Ed25519" />
                        </Grid>

                        <!-- Debugger / BMP -->
                        <TextBlock Text="Відлагоджувач (Black Magic Probe)" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Шлях до arm-none-eabi-gdb:" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="SettingsGdbPath" Margin="0,4,8,4"
                                       ToolTip="Залиште порожнім для авто-визначення" />
                            <Button    Grid.Row="0" Grid.Column="2" Content="..." Width="40" Margin="0,4,0,4" Click="PickGdbPath_Click" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Частота SWD, Hz:" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="SettingsBmpFreq" Margin="0,4,8,4" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Живлення:" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,4,0,4">
                                <RadioButton x:Name="SettingsPowerExternal" Content="Зовнішнє" GroupName="Power" Margin="0,0,16,0" />
                                <RadioButton x:Name="SettingsPowerProbe"    Content="Від BMP (tpwr)" GroupName="Power" />
                            </StackPanel>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Connect-under-reset:" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <CheckBox  Grid.Row="3" Grid.Column="1" x:Name="SettingsConnectReset" Margin="0,8,0,4"
                                       Content="Утримувати NRST при підключенні (для чипів зі сплячим SWD)" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Тайм-аут, сек:" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <TextBox   Grid.Row="4" Grid.Column="1" x:Name="SettingsTimeout" Margin="0,4,8,4" />
                        </Grid>

                        <!-- Logging / Station -->
                        <TextBlock Text="Журнал і станція" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Файл журналу (.db):" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <TextBox   Grid.Row="0" Grid.Column="1" x:Name="SettingsDbPath" Margin="0,4,8,4"
                                       ToolTip="Залиште порожнім для %LOCALAPPDATA%\FlashlightApp\flash_log.db" />
                            <Button    Grid.Row="0" Grid.Column="2" Content="..." Width="40" Margin="0,4,0,4" Click="PickDbPath_Click" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="ID станції:" VerticalAlignment="Center" Margin="0,4,8,4" />
                            <TextBox   Grid.Row="1" Grid.Column="1" x:Name="SettingsStationId" Margin="0,4,8,4" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Button Content="Зберегти"      Padding="20,8" Margin="0,0,8,0" FontWeight="Bold" Background="#0078D7" Foreground="White" BorderThickness="0" Click="SettingsSave_Click" />
                            <Button Content="Скинути до замовчень" Padding="14,8" Margin="0,0,8,0" Click="SettingsReset_Click" />
                            <TextBlock x:Name="SettingsStatus" VerticalAlignment="Center" Margin="12,0,0,0" Foreground="#1B8A1B" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
